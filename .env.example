# ========== 国产大语言模型API ==========

# 深度求索 DeepSeek (推荐首选，兼容OpenAI协议)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 通义千问 Qwen (阿里云)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# 月之暗面 Kimi / Moonshot
KIMI_API_KEY=your_kimi_api_key_here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# 智谱AI ChatGLM
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
ZHIPU_MODEL=glm-4

# 百度文心一言 ERNIE
WENXIN_API_KEY=your_wenxin_api_key
WENXIN_SECRET_KEY=your_wenxin_secret_key
WENXIN_MODEL=ernie-4.0-8k

# 百川智能 Baichuan
BAICHUAN_API_KEY=your_baichuan_api_key_here
BAICHUAN_BASE_URL=https://api.baichuan-ai.com/v1
BAICHUAN_MODEL=Baichuan4

# 腾讯混元 Hunyuan (需腾讯云API密钥)
HUNYUAN_SECRET_ID=your_hunyuan_secret_id
HUNYUAN_SECRET_KEY=your_hunyuan_secret_key
HUNYUAN_MODEL=hunyuan-pro

# 讯飞星火 Spark
SPARK_APP_ID=your_spark_app_id
SPARK_API_KEY=your_spark_api_key
SPARK_API_SECRET=your_spark_api_secret
SPARK_MODEL=4.0Ultra

# 私有化部署
LOCAL_LLM_URL=http://localhost:8000/v1

# ========== 国产图像生成API ==========

# 通义万相 (阿里)
TONGYI_WANXIANG_API_KEY=your_tongyi_wanxiang_key

# 文心一格 (百度)
WENXIN_YIGE_API_KEY=your_wenxin_yige_api_key
WENXIN_YIGE_SECRET=your_wenxin_yige_secret

# 智谱 CogView
COGVIEW_API_KEY=your_cogview_api_key

# 可灵 Kling (快手)
KLING_API_KEY=your_kling_api_key
KLING_API_SECRET=your_kling_api_secret

# ========== 国产语音合成API ==========

# 百度语音合成
BAIDU_TTS_APP_ID=your_baidu_tts_app_id
BAIDU_TTS_API_KEY=your_baidu_tts_api_key
BAIDU_TTS_SECRET=your_baidu_tts_secret

# 阿里云语音合成
ALI_TTS_ACCESS_ID=your_ali_tts_access_id
ALI_TTS_ACCESS_SECRET=your_ali_tts_access_secret
ALI_TTS_APP_KEY=your_ali_tts_app_key

# 讯飞语音合成
XUNFEI_TTS_APP_ID=your_xunfei_tts_app_id
XUNFEI_TTS_API_KEY=your_xunfei_tts_api_key
XUNFEI_TTS_API_SECRET=your_xunfei_tts_api_secret

# 腾讯云语音合成
TENCENT_TTS_SECRET_ID=your_tencent_tts_secret_id
TENCENT_TTS_SECRET_KEY=your_tencent_tts_secret_key

# ========== 国产视频生成API ==========

# 通义万相视频生成 (阿里千问系列) — 生视频首选
QWEN_VIDEO_API_KEY=your_qwen_video_api_key

# 可灵视频生成 (快手)
KLING_VIDEO_API_KEY=your_kling_video_api_key

# 即梦视频生成 (字节跳动/火山引擎)
JIMENG_API_KEY=your_jimeng_api_key
JIMENG_SECRET=your_jimeng_secret

# ========== 爬虫配置 ==========
PLAYWRIGHT_HEADLESS=true
REQUESTS_TIMEOUT=30
MAX_RETRY=3

# ========== 3D重建服务 ==========
NERF_STUDIO_URL=http://localhost:7007
GAUSSIAN_SPLATTING_URL=http://localhost:8080